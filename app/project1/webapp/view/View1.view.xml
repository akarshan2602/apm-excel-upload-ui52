<mvc:View
    controllerName="excelupload.project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:u="sap.ui.unified">

    <Page title="Generic Excel Upload">

        <content>

            <VBox class="sapUiSmallMargin">

                <u:FileUploader
                    id="fileUploader"
                    fileType="xlsx"
                    width="400px"
                    change="onFileUpload"/>

                <Button
                    text="Submit Selected Rows"
                    press="onSubmit"
                    class="sapUiSmallMarginTop"/>

                <Table
                    id="idTable"
                    mode="MultiSelect">
                </Table>

            </VBox>

        </content>

    </Page>

</mvc:View>